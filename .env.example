# =============================================================================
# OmniGestão Pro — variáveis de ambiente (copie para .env.local e preencha na Vercel)
# Nunca commite arquivos .env com segredos reais.
# Deploy na Vercel: Project Settings → Environment Variables — copie DATABASE_URL,
# DIRECT_URL e demais chaves. O script `npm run build` executa `prisma migrate deploy`
# para criar/atualizar tabelas no Postgres do deploy.
# =============================================================================

# Nome exibido em toda a interface (título do app, menus, PWA, WhatsApp).
NEXT_PUBLIC_APP_NAME="OmniGestão Pro"

# URL pública do deploy (CORS + metadados). Na Vercel pode ficar vazio; usamos VERCEL_URL.
# NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# -----------------------------------------------------------------------------
# Banco de dados — PostgreSQL (Supabase, Neon, Railway, etc.)
# Mesma URL para o dashboard no PC, PWA no celular e webhook na Vercel.
# -----------------------------------------------------------------------------
# Exemplo Supabase — Direct (5432):
# DATABASE_URL="postgresql://postgres:SENHA@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"
# Pooler PgBouncer / Transaction mode (6543) — típico com Prisma em runtime:
# DATABASE_URL="postgresql://postgres:SENHA@db.<PROJECT_REF>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=300"
# Conexão direta 5432 — use em DIRECT_URL para `prisma migrate dev` / CLI (migrations não passam pelo pooler transaction):
# DIRECT_URL="postgresql://postgres:SENHA@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# CORS (API) — opcional
# Domínios permitidos a chamar /api/* a partir do browser (origem cruzada).
# Inclua o domínio Vercel e o domínio customizado, separados por vírgula.
# Se vazio, apenas NEXT_PUBLIC_APP_URL e VERCEL_URL são considerados em lib/api-cors.
# ASSISTEC_API_CORS_ORIGINS=https://app.vercel.app,https://seudominio.com.br

# -----------------------------------------------------------------------------
# Segurança e sessões
# -----------------------------------------------------------------------------
ASSISTEC_SUBSCRIPTION_SECRET=

ASSISTEC_ADMIN_PIN=

ASSISTEC_CONTADOR_PIN=

# -----------------------------------------------------------------------------
# IA no servidor (IA Mestre, voz, WhatsApp, visão de produto)
# Defina UMA das opções abaixo (ou as duas; OpenAI tem prioridade):
# - OpenAI: https://platform.openai.com/api-keys
# - Google AI Studio (grátis): https://aistudio.google.com/apikey → use em GOOGLE_GENERATIVE_AI_API_KEY
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# -----------------------------------------------------------------------------
# WhatsApp — Webhook: POST https://SEU_DOMINIO/api/whatsapp/webhook
# Evolution API (ou compatível): envio de texto; configure o webhook no painel.
# -----------------------------------------------------------------------------
WHATSAPP_API_BASE=https://sua-api.com
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=nome_instancia

# Proteção do webhook (recomendado em produção): header x-webhook-token ou ?token=
ASSISTEC_WHATSAPP_WEBHOOK_SECRET=

ASSISTEC_WHATSAPP_DONO=

# Obrigatório para IA no WhatsApp (Rafael): só este número usa orquestrador, visão e confirmação de gasto.
ASSISTEC_WHATSAPP_OWNER_DIGITS=

# Plano para o orquestrador (bronze | prata | ouro). Padrão interno: ouro.
# ASSISTEC_PLANO_ASSINATURA=ouro

# Opcional: nome da empresa em mensagens WhatsApp (padrão = NEXT_PUBLIC_APP_NAME).
# ASSISTEC_EMPRESA_NOME=Minha Loja

# -----------------------------------------------------------------------------
# Impressão térmica ESC/POS (API /api/print/raw)
# -----------------------------------------------------------------------------
THERMAL_PRINT_HOST=127.0.0.1
THERMAL_PRINT_PORT=9100
# THERMAL_PRINT_HTTP_URL=http://127.0.0.1:9292/print

# -----------------------------------------------------------------------------
# Outras IAs (adicione quando usar)
# -----------------------------------------------------------------------------
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=
